# Solana base layer (where create_market / delegate_market / settle commit-back happen).
KESTREL_BASE_RPC_URL=https://api.devnet.solana.com

# MagicBlock Ephemeral Rollup endpoints (where open_market / close_market /
# settle_positions / commit_and_undelegate_market run).
KESTREL_ER_RPC_URL=https://devnet-as.magicblock.app/
KESTREL_ER_WS_URL=
KESTREL_VALIDATOR_LOOKUP_URL=https://devnet-router.magicblock.app/
KESTREL_VALIDATOR_LOOKUP_WS_URL=

# Admin keypair (must match Config.admin in the Kestrel program). Defaults to the
# CLI wallet under ~/.config/solana/id.json.
KESTREL_ADMIN_KEYPAIR=~/.config/solana/id.json

# Optional override for the program id; defaults to the address in the bundled IDL
# (`scheduler/src/idl/kestrel.json`, refreshed with `pnpm sync-idl` from repo root).
KESTREL_PROGRAM_ID=

# SPL USDC mint used when running `pnpm init-config` (init_config ix). On devnet,
# defaults to Circle devnet USDC if unset. Set explicitly if you use a custom mint.
KESTREL_USDC_MINT=

# Pyth PriceUpdate account pubkey to use for BTC/USD. Required if you need to
# migrate an older on-chain Config (v1) or you want to explicitly assert which
# oracle account is used for new markets.
KESTREL_BTC_USD_PRICE_UPDATE=

# Optional: write-through to Supabase (service role). If set, the scheduler will
# upsert the `markets` table with strike/status + lifecycle signatures as they
# happen (best-effort).
KESTREL_SUPABASE_URL=
KESTREL_SUPABASE_SERVICE_ROLE_KEY=

# Cadence and horizon.
KESTREL_WINDOW_SECS=300
# Rolling lookahead for scheduled markets (seconds). 86400 = 24h; 172800 = 48h.
KESTREL_HORIZON_SECS=86400
# Main loop interval (ms). Lower = tighter alignment to window edges on ER (50–60000).
KESTREL_TICK_MS=100

# ER window edges — defaults tuned for MagicBlock (fast open/close on the 5m boundary).
# Seconds to wait after on-chain open_ts / close_ts before sending open_market / close_market (0 = same second).
KESTREL_ONCHAIN_WINDOW_BUFFER_SECS=0
# How often to refetch the market list from base (ms). Lower = fresher status for phase-1 ER txs.
KESTREL_MARKET_LIST_REFRESH_MS=400
# Min ms between open_market or close_market retries per market (ER preflight / blockhash retries).
KESTREL_OPEN_CLOSE_COOLDOWN_MS=350
# Min ms between settle+commit passes per market (keep higher than ER open/close).
KESTREL_SETTLE_COOLDOWN_MS=8000

# How much liquidity to seed each market with on open_market (raw u64).
KESTREL_SEED_LIQUIDITY=1000000

# Optional: directory of agent keypair JSON files. If set, the scheduler will
# opportunistically delegate_agent for any AgentProfile whose owner has a
# keypair on disk and is not yet delegated. Leave empty to skip.
KESTREL_AGENT_KEYPAIRS_DIR=

# Logging. "pretty" formats with pino-pretty; "json" emits raw JSON lines.
KESTREL_LOG_FORMAT=pretty
KESTREL_LOG_LEVEL=info