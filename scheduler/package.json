{
  "name": "@kestrel/scheduler",
  "version": "0.1.0",
  "private": true,
  "description": "Kestrel scheduler: rolling 24h horizon of 5-minute BTC/USD markets, driven through full lifecycle on Solana base + MagicBlock ER",
  "main": "src/index.ts",
  "scripts": {
    "dev": "ts-node --transpile-only src/index.ts",
    "start": "ts-node --transpile-only src/index.ts",
    "prebuild": "node ../scripts/ensure-idl.mjs",
    "build": "tsc -p tsconfig.json",
    "init-config": "ts-node --transpile-only scripts/init-config.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@magicblock-labs/ephemeral-rollups-sdk": "^0.6.5",
    "@solana/web3.js": "^1.98.4",
    "@supabase/supabase-js": "^2.49.1",
    "dotenv": "^16.4.5",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
