# Kestrel agents runtime — copy to agents/.env and fill in.
#
# All three role processes (MarketOps / Trader / Risk-LP) share this env. Each
# loads its private key by role-name from KESTREL_AGENT_KEYPAIRS_DIR (the same
# convention scheduler/lifecycle/agents.ts uses), e.g.
#   ${KESTREL_AGENT_KEYPAIRS_DIR}/market_ops.json
#   ${KESTREL_AGENT_KEYPAIRS_DIR}/trader.json
#   ${KESTREL_AGENT_KEYPAIRS_DIR}/risk_lp.json

# RPCs ----------------------------------------------------------------------
KESTREL_BASE_RPC_URL=https://api.devnet.solana.com
KESTREL_ER_RPC_URL=https://devnet-as.magicblock.app/
KESTREL_VALIDATOR_LOOKUP_URL=https://devnet-router.magicblock.app/

# Next.js Agent API (optional) -----------------------------------------------
# When set (e.g. http://localhost:3000), trader + risk_lp use POST /api/v1/*
# to build place_bet / cancel_bet txs, and register_agent / deposit go through
# the same HTTP surface. Leave empty to keep using Anchor `.methods` only.
# After changing the program, run `pnpm anchor-build` at the repo root (or `pnpm sync-idl`
# after a plain `anchor build`) so app/scheduler/agents IDL copies stay in sync; restart Next if needed.
# KESTREL_API_BASE_URL=http://localhost:3000

# Program / accounts --------------------------------------------------------
# Optional: override the program id (else use address in `agents/src/idl/kestrel.json`).
# KESTREL_PROGRAM_ID=
# Pyth-style BTC/USD price update account used by every market.
KESTREL_BTC_USD_PRICE_UPDATE=71wtTRDY8Gxgw56bXFt2oc6qeAbTxzStdNiC425Z51sr

# Agent keypairs ------------------------------------------------------------
# Directory holding role keypair files: market_ops.json / trader.json /
# risk_lp.json. The MarketOps role doubles as `config.admin` in this hack
# build, so its keypair must match the admin used to init the config.
KESTREL_AGENT_KEYPAIRS_DIR=~/.config/solana/kestrel-agents
KESTREL_ADMIN_KEYPAIR=~/.config/solana/id.json

# Supabase (optional) -------------------------------------------------------
# Used to upsert public.agents (role/label) and to read live event timelines
# from the indexer. Falls back to a no-op when missing.
KESTREL_SUPABASE_URL=
KESTREL_SUPABASE_SERVICE_ROLE_KEY=

# Trader policy template ----------------------------------------------------
# Trader's honest bet size and policy cap; the scripted over-cap demo bet at
# +10s into a window uses (max + 1) so it deterministically fails.
AGENTS_TRADER_BASE_SIZE=200000
AGENTS_TRADER_MAX_STAKE=500000
# On-chain max open position slots per agent (default 16). Raise for long demos.
# AGENTS_TRADER_MAX_OPEN_POSITIONS=16

# Risk-LP / Hedger policy template ------------------------------------------
AGENTS_RISK_LP_MAX_STAKE=250000
# On-chain max distinct open markets per agent (default 16). Was 4; raise for long demos.
# AGENTS_RISK_LP_MAX_OPEN_POSITIONS=16

# MarketOps tuning ----------------------------------------------------------
# Halt the market for AGENTS_OPS_FORCE_HALT_SECS every Nth market for the
# guaranteed Halt/Resume demo card. Set to 0 to disable.
AGENTS_OPS_FORCE_HALT_EVERY_MARKETS=4
AGENTS_OPS_FORCE_HALT_SECS=20
# Auto-halt when oracle publish_time falls behind by more than this.
AGENTS_OPS_STALE_THRESHOLD_SECS=30

# Demo timing inside a single market window (seconds from open_ts) ---------
AGENTS_TRADER_OVER_CAP_AT_SEC=10
AGENTS_TRADER_WRONG_ALLOWLIST_AT_SEC=20

# Withdraw demo (base layer, after settle / commit_and_undelegate_agent) ----
# pnpm --filter @kestrel/agents withdraw -- --role trader
# pnpm --filter @kestrel/agents withdraw -- --role risk_lp --amount 1000000
